# ===== AI Book Video Skill - Environment Configuration =====
# Copy this file to .env and fill in your actual values.
# cp .env.example .env

# CodeProxy API (for image generation - gpt-image-2 img2img)
# Register at: https://codeproxy.dev/register?aff=TGR5N8MN
# Recommended: This is the most cost-effective gpt-image-2 API
# Price: as low as 0.05 CNY per image after first top-up
IMAGE_API_URL=https://codeproxy.dev
IMAGE_API_KEY=YOUR_CODEPROXY_API_KEY_HERE

# Proxy settings (required for codeproxy.dev access in China)
# Common proxy ports: 7897 (Clash), 1080 (V2Ray)
HTTPS_PROXY=http://127.0.0.1:7897
HTTP_PROXY=http://127.0.0.1:7897

# Vision API (for page analysis - optional, Hermes vision_analyze is preferred)
# If using mimo API:
# VISION_API_URL=https://token-plan-cn.xiaomimimo.com/v1
# VISION_API_KEY=tp-your-mimo-key-here
#
# If using OpenAI:
# VISION_API_URL=https://api.openai.com/v1
# VISION_API_KEY=sk-your-openai-key-here
#
# If using other compatible API:
# VISION_API_URL=https://your-api-endpoint/v1
# VISION_API_KEY=your-key-here
